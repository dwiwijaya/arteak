---
import { useTranslations, type Lang } from '../data/i18n';
import type { Category } from '../data/products';

export interface Props {
  lang: Lang;
  productsHref?: string;
  homeHref?: string;
}
const {
  lang,
  productsHref = '/products',
  homeHref = '/',
} = Astro.props;
const t = useTranslations(lang);

const collections: { id: Category; key: string }[] = [
  { id: 'washbasin-designer', key: 'cat.washbasin-designer' },
  { id: 'washbasin-root',     key: 'cat.washbasin-root' },
  { id: 'washbasin-stone',    key: 'cat.washbasin-stone' },
  { id: 'cabinet',            key: 'cat.cabinet' },
  { id: 'mirror',             key: 'cat.mirror' },
  { id: 'home-accessory',     key: 'cat.home-accessory' },
];

const infoLinks = [
  { key: 'info.quality',      tab: 'quality' },
  { key: 'info.care',         tab: 'care' },
  { key: 'info.sustainability',tab: 'sustainability' },
  { key: 'info.teak',         tab: 'teak' },
  { key: 'info.payment',      tab: 'payment' },
  { key: 'info.shipping',     tab: 'shipping' },
];
---

<footer id="contact">
  <div class="footer-top">
    <!-- Brand -->
    <div class="footer-brand">
      <a href={homeHref} class="footer-logo">ARR<span>TEAK</span></a>
      <p class="footer-desc" data-i18n="footer.desc">{t('footer.desc')}</p>
      <div class="footer-social">
        <a href="#" class="social-link" aria-label="Instagram">ig</a>
        <a href="https://wa.me/6281234567890" class="social-link" aria-label="WhatsApp">wa</a>
        <a href="#" class="social-link" aria-label="Facebook">fb</a>
      </div>
    </div>

    <!-- Collections -->
    <div>
      <div class="footer-col-title" data-i18n="footer.col.collections">{t('footer.col.collections')}</div>
      <ul class="footer-links">
        {collections.map(({ id, key }) => (
          <li>
            <a
              href={`${productsHref}?filter=${id}`}
              data-i18n={key}
            >
              {t(key as any)}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Information -->
    <div>
      <div class="footer-col-title" data-i18n="footer.col.info">{t('footer.col.info')}</div>
      <ul class="footer-links">
        {infoLinks.map(({ key, tab }) => (
          <li>
            <button class="footer-info-link" data-tab={tab} data-i18n={key}>
              {t(key as any)}
            </button>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <!-- <div class="footer-contact">
      <div class="footer-contact-list">
        <div class="footer-contact-row">
          <div class="footer-contact-label" data-i18n="contact.phone.label">{t('contact.phone.label')}</div>
          <a class="footer-contact-value" href="tel:+6281234567890">+62 810</a>
          <div class="footer-contact-meta">
            <span data-i18n="contact.hours.days">{t('contact.hours.days')}</span>
            <span data-i18n="contact.hours.time">{t('contact.hours.time')}</span>
          </div>
        </div>

        <div class="footer-contact-row">
          <div class="footer-contact-label" data-i18n="contact.studio.label">{t('contact.studio.label')}</div>
          <div class="footer-contact-value footer-contact-value--text" data-i18n="contact.studio.name">{t('contact.studio.name')}</div>
          <div class="footer-contact-meta">
            <span data-i18n="contact.studio.address.1">{t('contact.studio.address.1')}</span>
            <span data-i18n="contact.studio.address.2">{t('contact.studio.address.2')}</span>
          </div>
        </div>

        <div class="footer-contact-row footer-contact-row--actions">
          <a class="footer-contact-email" href="mailto:info@arrteak.com">info@arrteak.com</a>
          <a class="footer-contact-cta" href="/contact" data-i18n="contact.form">{t('contact.form')}</a>
        </div>
      </div>
    </div> -->
  </div>

  <div class="footer-bottom">
    <span data-i18n="footer.rights">{t('footer.rights')}</span>
    <span data-i18n="footer.made">{t('footer.made')}</span>
  </div>
</footer>

<style>
footer {
  background: var(--wood-dark);
  color: rgba(245,240,232,0.55);
  padding: 5rem 5rem 2rem;
}

.footer-top {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 4rem;
  margin-bottom: 3.5rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(245,240,232,0.1);
}

.footer-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--cream);
  text-decoration: none;
  display: block;
  margin-bottom: 1rem;
}
.footer-logo span { color: var(--wood-accent); }

.footer-desc {
  font-size: 0.82rem;
  line-height: 1.8;
  margin-bottom: 1.5rem;
  max-width: 280px;
}

.footer-social { display: flex; gap: 0.8rem; }
.social-link {
  width: 32px; height: 32px;
  border: 1px solid rgba(245,240,232,0.18);
  display: flex; align-items: center; justify-content: center;
  color: rgba(245,240,232,0.45);
  text-decoration: none;
  font-size: 0.75rem;
  transition: all 0.2s;
}
.social-link:hover { border-color: var(--wood-accent); color: var(--wood-accent); }

.footer-col-title {
  font-size: 0.62rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.35);
  margin-bottom: 1.4rem;
}

.footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}
.footer-links a,
.footer-links button.footer-info-link {
  font-size: 0.8rem;
  color: rgba(245,240,232,0.5);
  text-decoration: none;
  background: none;
  border: none;
  font-family: 'Jost', sans-serif;
  font-weight: 300;
  text-align: left;
  padding: 0;
  transition: color 0.2s;
  display: block;
  width: 100%;
}
.footer-links a:hover,
.footer-links button.footer-info-link:hover { color: var(--wood-accent); }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 0.68rem;
  color: rgba(245,240,232,0.28);
}
.footer-contact-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.footer-contact-row {
  padding-top: 0.05rem;
}
.footer-contact-row + .footer-contact-row {
  padding-top: 1rem;
  border-top: 1px solid rgba(245,240,232,0.08);
}
.footer-contact-label {
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.34);
  margin-bottom: 0.45rem;
}
.footer-contact-value {
  display: inline-block;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.02rem;
  color: var(--cream);
  text-decoration: none;
  margin-bottom: 0.35rem;
}
.footer-contact-value--text {
  display: block;
}
.footer-contact-meta {
  display: grid;
  gap: 0.2rem;
  font-size: 0.78rem;
  line-height: 1.6;
  color: rgba(245,240,232,0.52);
}
.footer-contact-row--actions {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}
.footer-contact-email {
  font-size: 0.82rem;
  color: var(--cream);
  text-decoration: none;
  line-height: 1.5;
}
.footer-contact-cta {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 0.1rem 0;
  border-bottom: 1px solid rgba(245,240,232,0.22);
  color: rgba(245,240,232,0.72);
  text-decoration: none;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  transition: color 0.2s, border-color 0.2s;
}
.footer-contact-cta:hover {
  border-color: var(--wood-accent);
  color: var(--wood-accent);
}

@media (max-width: 1000px) {
  footer { padding: 4rem 3rem 2rem; }
  .footer-top { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
}
@media (max-width: 600px) {
  footer { padding: 3rem 1.5rem 1.5rem; }
  .footer-top { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom { flex-direction: column; gap: 0.4rem; text-align: center; }
}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.footer-info-link').forEach(btn => {
    btn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('ka:openinfo', { detail: { tab: btn.dataset.tab } }));
    });
  });
</script>
