---
import { useTranslations, type Lang } from '../data/i18n';
import { categories } from '../data/products';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="categories" class="section section--cream">
  <div class="cat-header">
    <div>
      <div class="section-tag" data-i18n="section.collections">{t('section.collections')}</div>
      <h2 class="section-title" data-i18n="section.collections.title">{t('section.collections.title')}</h2>
    </div>
    <a href="#products" class="btn-ghost" data-i18n="section.collections.all">{t('section.collections.all')}</a>
  </div>

  <div class="cat-grid">
    {categories.map(({ id, img, span }) => (
      <button
        class={`cat-item ${span ? 'cat-item--span' : ''} dropdown-filter-link`}
        data-filter={id}
        aria-label={t(`cat.${id}` as any)}
      >
        <img
          src={img}
          alt={t(`cat.${id}` as any)}
          class="cat-img"
          loading="lazy"
        />
        <div class="cat-overlay" aria-hidden="true"></div>
        <div class="cat-info">
          <div class="cat-name" data-i18n={`cat.${id}`}>{t(`cat.${id}` as any)}</div>
          <div class="cat-sub" data-i18n={`cat.${id}.sub`}>{t(`cat.${id}.sub` as any)}</div>
        </div>
        <span class="cat-arrow" aria-hidden="true">→</span>
      </button>
    ))}
  </div>
</section>

<style>
.cat-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 2.5rem;
}

.cat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: auto auto;
  gap: 2px;
}

.cat-item {
  position: relative;
  overflow: hidden;
  cursor: pointer;
  aspect-ratio: 3/4;
  background: var(--grain);
  border: none;
  padding: 0;
  text-align: left;
}
.cat-item--span {
  grid-column: span 2;
  grid-row: span 2;
  aspect-ratio: auto;
}

.cat-img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  filter: sepia(6%);
  display: block;
}
.cat-item:hover .cat-img { transform: scale(1.06); }

.cat-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(44,31,14,0.75) 0%, transparent 55%);
  opacity: 0.65;
  transition: opacity 0.3s;
}
.cat-item:hover .cat-overlay { opacity: 0.9; }

.cat-info {
  position: absolute;
  bottom: 1.2rem; left: 1.2rem; right: 1.2rem;
}
.cat-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-weight: 400;
  color: white;
  margin-bottom: 0.2rem;
}
.cat-item--span .cat-name { font-size: 1.7rem; }
.cat-sub {
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}

.cat-arrow {
  position: absolute;
  top: 1rem; right: 1rem;
  width: 30px; height: 30px;
  border: 1px solid rgba(255,255,255,0.35);
  display: flex; align-items: center; justify-content: center;
  color: white;
  font-size: 0.85rem;
  opacity: 0;
  transform: translate(4px,-4px);
  transition: all 0.25s;
}
.cat-item:hover .cat-arrow { opacity: 1; transform: translate(0,0); }

/* ─── RESPONSIVE ─────────────────────────────────────── */
@media (max-width: 1000px) {
  .cat-grid { grid-template-columns: repeat(2, 1fr); }
  .cat-item--span { grid-column: span 2; aspect-ratio: 16/7; }
}
@media (max-width: 600px) {
  .cat-grid { grid-template-columns: 1fr 1fr; }
  .cat-item--span { aspect-ratio: 16/9; }
  .cat-header { flex-direction: column; gap: 1rem; align-items: flex-start; }
}
</style>

<script>
  // Wire up category filter clicks
  document.querySelectorAll<HTMLButtonElement>('.cat-item[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      document.dispatchEvent(new CustomEvent('ka:filter', { detail: { filter } }));
      document.getElementById('products')?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
