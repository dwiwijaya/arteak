---
import { useTranslations, type Lang } from '../data/i18n';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <div class="hero-left">
    <div class="hero-tag">{t('hero.tag')}</div>
    <h1 class="hero-title">
      <span data-i18n="hero.title1">{t('hero.title1')}</span><br />
      <em data-i18n="hero.title2">{t('hero.title2')}</em><br />
      <span data-i18n="hero.title3">{t('hero.title3')}</span>
    </h1>
    <p class="hero-sub" data-i18n="hero.sub">{t('hero.sub')}</p>
    <div class="hero-cta">
      <a href="#products" class="btn-primary" data-i18n="hero.cta1">{t('hero.cta1')}</a>
      <a href="#why" class="btn-ghost" data-i18n="hero.cta2">{t('hero.cta2')}</a>
    </div>
  </div>

  <div class="hero-right">
    <img
      class="hero-img"
      src="https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=1000&q=85"
      alt="Handcrafted teak washbasin"
      fetchpriority="high"
      loading="eager"
    />
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-badge">
      <span class="hero-badge-num">3K+</span>
      <span class="hero-badge-label" data-i18n="hero.badge">{t('hero.badge')}</span>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-top: var(--nav-h);
  overflow: hidden;
}

/* ─── LEFT ────────────────────────────────────────────── */
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 6rem 4rem 6rem 5rem;
  position: relative;
}
.hero-left::before {
  content: '';
  position: absolute;
  top: 35%; left: -8%;
  width: 55%; height: 60%;
  background: radial-gradient(ellipse, rgba(196,133,58,0.07) 0%, transparent 70%);
  pointer-events: none;
}

.hero-tag {
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--wood-accent);
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  opacity: 0;
  transform: translateY(16px);
  animation: heroFade 0.7s ease 0.1s forwards;
}
.hero-tag::before {
  content: '';
  width: 28px; height: 1px;
  background: var(--wood-accent);
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3.2rem, 5vw, 5.5rem);
  font-weight: 300;
  line-height: 1.05;
  color: var(--wood-dark);
  margin-bottom: 1.5rem;
  opacity: 0;
  transform: translateY(16px);
  animation: heroFade 0.7s ease 0.22s forwards;
}
.hero-title em { font-style: italic; color: var(--wood-accent); }

.hero-sub {
  font-size: 0.88rem;
  line-height: 1.85;
  color: var(--text-sub);
  max-width: 380px;
  margin-bottom: 3rem;
  opacity: 0;
  transform: translateY(16px);
  animation: heroFade 0.7s ease 0.34s forwards;
}

.hero-cta {
  display: flex;
  gap: 1.5rem;
  align-items: center;
  opacity: 0;
  transform: translateY(16px);
  animation: heroFade 0.7s ease 0.46s forwards;
}

/* ─── RIGHT ───────────────────────────────────────────── */
.hero-right {
  position: relative;
  overflow: hidden;
}
.hero-img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: sepia(8%) contrast(1.04);
  transition: transform 8s ease;
}
.hero-right:hover .hero-img { transform: scale(1.03); }
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(44,31,14,0.18) 0%, transparent 55%);
}

.hero-badge {
  position: absolute;
  bottom: 2.5rem; left: 2.5rem;
  background: rgba(250,248,244,0.93);
  backdrop-filter: blur(8px);
  border: 1px solid var(--border);
  padding: 1rem 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.hero-badge-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 600;
  color: var(--wood-accent);
  line-height: 1;
}
.hero-badge-label {
  font-size: 0.62rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-sub);
}

@keyframes heroFade {
  to { opacity: 1; transform: translateY(0); }
}

/* ─── RESPONSIVE ─────────────────────────────────────── */
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-left { padding: 3rem 2rem 2.5rem; }
  .hero-right { height: 55vw; min-height: 260px; }
  .hero-badge { display: none; }
}
</style>
